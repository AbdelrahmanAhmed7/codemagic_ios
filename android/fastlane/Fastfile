default_platform(:android)

platform :android do
  desc "Distribute a new build to app distribution"
  lane :distribute do
    sh "flutter clean"
    sh "flutter pub get"
    sh "flutter build apk --release"
    unless ENV['FIREBASE_TOKEN'] && !ENV['FIREBASE_TOKEN'].empty?
      UI.user_error!("Missing FIREBASE_TOKEN environment variable. Set it securely (e.g., CI secret) before running this lane.")
    end
    firebase_app_distribution(
      app: "1:477815114095:android:3d6f2dbfd9d06958afc09a",
      firebase_cli_token: ENV['FIREBASE_TOKEN'],
      android_artifact_type: "APK",
      android_artifact_path: "../build/app/outputs/flutter-apk/app-release.apk",
      testers: "omaralsalhani7@gmail.com", 
      release_notes: "Automated build from Fastlane"
    )
  end
end
